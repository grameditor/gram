# Adapted from: https://aur.archlinux.org/packages/gram-editor-bin
pkgname=gram-bin
pkgver=$RELEASE_VERSION
pkgrel=1
pkgdesc="A code editor for humanoid apes and grumpy toads"

provides=(gram-editor gram)
conflicts=(gram-editor gram)

arch=('x86_64')

url="https://codeberg.org/GramEditor/gram"
license=(GPL-3.0-or-later AGPL-3.0-or-later Apache-2.0)

depends=('fontconfig'
    'gcc-libs'
    'glibc'
    'libxcb'
    'libxkbcommon'
    'libxkbcommon-x11'
    'openssl'
    'sqlite'
    'vulkan-driver'
    'vulkan-icd-loader'
    'vulkan-tools'
    'wayland'
    'zlib')

optdepends=(
    'rustup: permits installing rust-based extensions'
    'clangd: improved C/C++ language support'
    'eslint: improved Javascript language support'
    'pyright: improved Python language support'
    'python-lsp-server: improved Python language support'
    'ty: improved Python language support'
    'ruff: provides Python linting'
    'rust-analyzer: improved Rust language support'
    'gopls: improved gopls language support'
    'yaml-language-server: improved YAML language support'
    'bash-language-server: improved bash language support'
    'tailwindcss-language-server: improved CSS language support'
    'zls: improved Zig language support'
    'vscode-html-languageserver: improved HTML language support'
    'lua-language-server: improved Lua language support'
    'typescript-language-server: improved TypeScript language support'
)

source=("$pkgname-$pkgver.tar.gz::$url/releases/download/${pkgver}/gram-linux-x86_64-${pkgver}.tar.gz")
sha256sums=(.)

package() {
    cd $srcdir/gram.app

    install -Dm0755 bin/gram "$pkgdir/usr/bin/gram"
    install -Dm0755 libexec/gram-editor "$pkgdir/usr/lib/gram/gram-editor"
    install -Dm0644 licenses.md "$pkgdir/usr/share/licenses/gram/licenses.md"
    install -Dm0644 share/applications/gram.desktop "$pkgdir/usr/share/applications/app.liten.Gram.desktop"
    install -Dm0644 share/icons/hicolor/scalable/apps/app.liten.Gram.svg "$pkgdir/usr/share/icons/hicolor/scalable/apps/app.liten.Gram.svg"
    install -Dm0644 share/icons/hicolor/symbolic/apps/app.liten.Gram-symbolic.svg "$pkgdir/usr/share/icons/hicolor/symbolic/apps/app.liten.Gram-symbolic.svg"
}
