[
  {
    "label": "Debug Gram (CodeLLDB)",
    "adapter": "CodeLLDB",
    "build": {
      "label": "Build Gram",
      "command": "cargo",
      "env": { "GRAM_STATELESS": "1" },
      "args": ["build"],
    },
  },
  {
    "label": "Debug Gram (GDB)",
    "adapter": "GDB",
    "build": {
      "label": "Build Gram",
      "command": "cargo",
      "env": { "GRAM_STATELESS": "1" },
      "args": ["build"],
    },
  },
]
