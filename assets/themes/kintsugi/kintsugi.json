        "search.match_background": "#6c7a8a40",
        "panel.background": "#131314",
        "pane_group.border": "#2a2a28",
        "scrollbar.thumb.background": "#33352d90",
        "scrollbar.thumb.hover_background": "#75715e80",
        "scrollbar.thumb.active_background": "#b8943a50",
        "scrollbar.thumb.border": "#33352d90",
        "scrollbar.track.background": "#161618",
        "scrollbar.track.border": "#33352d90",
        "editor.foreground": "#dddddd",
        "editor.background": "#161618",
        "editor.gutter.background": "#161618",
        "editor.active_line.background": "#1d1d1c",
        "editor.line_number": "#444444",
        "editor.active_line_number": "#dddddd",
        "editor.wrap_guide": "#2a2a28",
        "editor.active_wrap_guide": "#2a2a28",
        "editor.document_highlight.bracket_background": "#6c7a8a50",
        "terminal.background": "#131314",
        "terminal.ansi.black": "#131314",
        "terminal.ansi.bright_black": "#444444",
        "terminal.ansi.red": "#b38f8f",
        "terminal.ansi.bright_red": "#d9a6a6",
        "terminal.ansi.green": "#a3be8c",
        "terminal.ansi.bright_green": "#c3de9c",
        "terminal.ansi.yellow": "#ebcb8b",
        "terminal.ansi.bright_yellow": "#fbe4a8",
        "terminal.ansi.blue": "#6c7a8a",
        "terminal.ansi.bright_blue": "#8fa3b3",
        "terminal.ansi.magenta": "#b3a3d3",
        "terminal.ansi.bright_magenta": "#d3a3d3",
        "terminal.ansi.cyan": "#6ac6f2",
        "terminal.ansi.bright_cyan": "#8ac6f2",
        "terminal.ansi.white": "#dddddd",
        "terminal.ansi.bright_white": "#ffffff",
        "link_text.hover": "#8fa3b3",
        "conflict": "#b38f8f",
        "created": "#a3be8c",
        "deleted": "#b38f8f",
        "error": "#C97D7DFF",
        "error.border": "#8b6b6b50",
        "error.background": "#8b6b6b50",
        "hidden": "#ccccc7",
        "hint": "#dbac35",
        "ignored": "#75715e",
        "info": "#6c7a8a",
        "info.border": "#6b7b8b50",
        "modified": "#ebcb8b",
        "warning": "#ebcb8b",
        "warning.border": "#8b8b6b50",
        "warning.background": "#8b8b6b50",
        "players": [
          {
            "cursor": "#E08542",
            "background": "#E08542",
            "selection": "#E0854220"
          }
        ],
        "syntax": {
          "attribute": { "color": "#798283" },
          "boolean": { "color": "#DB9833" },
          "comment": { "color": "#5f5f5f", "font_style": "italic" },
          "comment.doc": { "color": "#5f5f5f", "font_style": "italic" },
          "constant": { "color": "#DB9833" },
          "constructor": { "color": "#DBAD49", "font_weight": 800.0 },
          "emphasis.strong": { "color": "#DBAD49", "font_weight": 800.0 },
          "function": { "color": "#798283" },
          "keyword": { "color": "#D66848", "font_weight": 800.0 },
          "label": { "color": "#798283" },
          "number": { "color": "#DB9833" },
          "operator": { "color": "#E08542" },
          "preproc": { "color": "#798283" },
          "property": { "color": "#798283" },
          "punctuation": { "color": "#7f7b66" },
          "punctuation.bracket": { "color": "#7f7b66" },
          "punctuation.delimiter": { "color": "#7f7b66" },
          "punctuation.list_marker": { "color": "#7f7b66" },
          "punctuation.special": { "color": "#7f7b66" },
          "string": { "color": "#cc7f66" },
          "string.escape": { "color": "#798283" },
          "string.regex": { "color": "#cc7f66" },
          "string.special": { "color": "#cc7f66" },
          "string.special.symbol": { "color": "#cc7f66" },
          "tag": { "color": "#DBAD49", "font_weight": 800.0 },
          "text.literal": { "color": "#cc7f66" },
          "title": { "color": "#798283" },
          "type": { "color": "#E08542" },
          "variable": { "color": "#BCAC8F" },
          "variable.special": { "color": "#BCAC8F" }
