{
  "$schema": "https://zed.dev/schema/themes/v0.2.0.json",
  "author": "Giacomo Cavalieri",
  "name": "Kintsugi",
  "themes": [
    {
      "name": "Kintsugi Dark Flared",
      "appearance": "dark",
      "style": {
        "text": "#BCAC8FFF",
        "text.muted": "#7F7B66FF",
        "icon": "#BCAC8FFF",
        "icon.muted": "#7F7B66FF",
        "accents": [],
        "border": "#2a2a28",
        "border.variant": "#2a2a28",
        "border.focused": "#b8943a",
        "border.selected": "#2a2a28",
        "border.transparent": "#2a2a28",
        "border.disabled": "#2a2a28",
        "elevated_surface.background": "#292928",
        "surface.background": "#131314",
        "background": "#161618",
        "background.appearance": "opaque",
        "element.background": "#3e3b2c",
        "element.hover": "#2a2a2850",
        "element.selected": "#393b31",
        "drop_target.background": "#414339",
        "ghost_element.hover": "#2a2a2850",
        "ghost_element.selected": "#393b31",
        "status_bar.background": "#131314",
        "title_bar.background": "#131314",
        "toolbar.background": "#161618",
        "tab_bar.background": "#131314",
        "tab.inactive_background": "#1a1a1d",
