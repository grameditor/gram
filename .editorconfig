root = true

[*]
charset = utf-8
end_of_line = lf
indent_size = 4
indent_style = space
insert_final_newline = true
max_line_length = 120
trim_trailing_whitespace = true

[{*.{json,jsonc},*.sh,*.{yaml,yml}}]
indent_size = 2

[*.{bat,ps1}]
end_of_line = crlf
indent_size = 2
insert_final_newline = false
